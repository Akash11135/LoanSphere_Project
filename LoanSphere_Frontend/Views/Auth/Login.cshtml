@{
    ViewData["Title"] = "Login";
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <meta name="viewport"
          content="width=device-width,initial-scale=1" />

    <title>LoanSphere Login</title>

    <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;700;800&display=swap"
          rel="stylesheet">

    <style>

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Manrope',sans-serif;
        }

        body {
            height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
            background: linear-gradient(135deg,#eef2ff,#f8fafc);
        }

        .login-box {
            width: 430px;
            background: white;
            padding: 45px;
            border-radius: 24px;
            box-shadow: 0 20px 60px rgba(0,0,0,.08);
        }

        .logo {
            font-size: 34px;
            font-weight: 800;
            color: #1e3a5f;
            margin-bottom: 10px;
        }

        .sub {
            color: #64748b;
            margin-bottom: 35px;
        }

        label {
            display: block;
            font-weight: 700;
            font-size: 14px;
            margin-bottom: 8px;
            margin-top: 20px;
        }

        input {
            width: 100%;
            padding: 16px;
            border: 1px solid #dbe2ea;
            border-radius: 12px;
            font-size: 15px;
            outline: none;
        }

            input:focus {
                border-color: #1e3a5f;
            }

        button {
            margin-top: 30px;
            width: 100%;
            padding: 16px;
            border: none;
            background: #0f172a;
            color: white;
            font-weight: 700;
            border-radius: 14px;
            cursor: pointer;
        }

            button:hover {
                background: #1e3a5f;
            }

        .error {
            background: #fee2e2;
            color: #dc2626;
            padding: 14px;
            border-radius: 10px;
            margin-bottom: 18px;
        }

        .demo {
            margin-top: 20px;
            padding: 15px;
            background: #eff6ff;
            border-radius: 12px;
            font-size: 14px;
        }

        a {
            text-decoration: none;
            color: #1e3a5f;
            font-weight: 700;
        }

        .register {
            margin-top: 25px;
            text-align: center;
        }

    </style>
</head>

<body>

    <div class="login-box">

        <div class="logo">
            LoanSphere
        </div>

        <div class="sub">
            Login to your lending dashboard
        </div>

        @if (ViewBag.Error != null)
        {
            <div class="error">
                @ViewBag.Error
            </div>
        }

        <form method="post">

            <label>Email</label>
            <input type="email"
                   name="email"
                   placeholder="Enter email" />

            <label>Password</label>
            <input type="password"
                   name="password"
                   placeholder="Enter password" />

            <button type="submit">
                Login
            </button>

        </form>

        <div class="demo">
            <b>Dummy Login</b><br><br>
            Email: akash@gmail.com <br>
            Password: akash123
        </div>

        <div class="register">
            No account?
            <a asp-controller="Auth"
               asp-action="Register">
                Register
            </a>
        </div>

    </div>

</body>
</html>