
@{
    ViewData["Title"] = "Home Page";
}

@* <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&display=swap" rel="stylesheet"> *@
<style>
    html {
        scroll-behavior: smooth;
    }

    body {
        margin: 0;
        background: #F7FAFC;
        scroll-padding-top: 100px;
       
    }

    .main-container {
        max-width: 1280px;
        margin: auto;
        padding: 0 2rem;
    }

    header {
        position: sticky;
        top: 0;
        z-index: 1000;
        display: flex;
        justify-content: center;
        background: #F7FAFC;
        backdrop-filter: blur(10px);
    }

    .nav-container {
        width: 100%;
        height: 84px;
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 20px 20px;
        border-bottom: 1px solid #d7dde3;
        transition: .3s;
    }

        .nav-container.scrolled {
            background: rgba(247,250,252,.95);
            box-shadow: 0 8px 24px rgba(0,0,0,.05);
        }

    .nav-title {
        font-size: 34px;
        font-weight: 700;
        color: #004A7C;
    }

    .nav-links ul {
        list-style: none;
        display: flex;
        gap: 2rem;
        margin: 0;
        padding: 0;
    }

    .nav-links a {
        text-decoration: none;
        color: #475569;
        font-weight: 500;
        position: relative;
    }

        .nav-links a:after {
            content: "";
            position: absolute;
            left: 0;
            bottom: -6px;
            height: 2px;
            width: 0;
            background: #004A7C;
            transition: .3s;
        }

        .nav-links a:hover:after {
            width: 100%;
        }

    .nav-actions {
        display: flex;
        gap: 1rem;
    }

    .btns {
        background: #003358;
        color: #fff;
        border: none;
        border-radius: 12px;
        padding: .8rem 1.4rem;
        font-weight: 600;
    }

        .btns a {
            color: white;
            text-decoration: none;
        }

        .btns:hover {
            background: #005A8D;
            transform: translateY(-2px);
        }

    .title-container {
        padding: 4rem 0 2rem;
        animation: fadeUp 1s ease;
    }

    @@keyframes fadeUp {
        from {
            opacity: 0;
            transform: translateY(25px)
        }

        to {
            opacity: 1;
            transform: none
        }
    }

    .title-container h1 {
        font-size: 78px;
        line-height: 1.05;
        font-weight: 800;
        color: #003358;
        margin: .25rem 0;
    }

    .title-container p {
        max-width: 700px;
        font-size: 1.25rem;
        color: #42474F;
        margin-top: 1rem;
    }

    .section-block {
        padding-top: 5rem;
        scroll-margin-top: 110px;
    }

    /* FIXED CARD GRID */
    .services-container {
        margin-top: 3rem;
        display: grid;
        grid-template-columns: repeat(auto-fit,minmax(340px,1fr));
        gap: 2rem;
    }

    .service-card {
        background: #F5F7F9;
        border-radius: 22px;
        padding: 32px;
        height: 420px;
        display: flex;
        flex-direction: column;
        justify-content: space-between;
        transition: .35s;
    }

        .service-card:hover {
            transform: translateY(-10px);
            box-shadow: 0 18px 40px rgba(0,0,0,.08);
        }

    .icon-box {
        width: 52px;
        height: 52px;
        border-radius: 14px;
        background: #E9EEF3;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 20px;
    }

    .service-card h4 {
        margin-top: 1rem;
        font-size: 32px;
        color: #003358;
    }

    .service-card p {
        color: #42474F;
        padding-bottom: 2rem;
        border-bottom: 1px solid #d8dde2;
    }

    .card-footer {
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .learn-more {
        border: none;
        background: none;
        font-weight: 600;
        color: #003358;
    }

    .feature-section {
        margin-top: 5rem;
        background: #F5F7F9;
        border-radius: 30px;
        padding: 60px;
        display: flex;
        flex-wrap: wrap;
        gap: 4rem;
        align-items: center;
        justify-content: space-between;
    }

    .feature-text {
        flex: 1;
        min-width: 320px;
    }

        .feature-text h2 {
            font-size: 42px;
            color: #003358;
        }

    .feature-item {
        display: flex;
        gap: 14px;
        margin-top: 1.2rem;
    }

    .feature-icon {
        width: 40px;
        height: 40px;
        border-radius: 12px;
        background: #E9EEF3;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    /* FIXED IMAGES */
    .feature-image {
        max-width: 540px;
        width: 100%;
        margin: auto;
        position: relative;
    }

        .feature-image img {
            width: 100%;
            height: 420px;
            object-fit: cover;
            border-radius: 28px;
        }

    .stat-card {
        position: absolute;
        left: 30px;
        bottom: -20px;
        background: #fff;
        padding: 20px 30px;
        border-radius: 15px;
        box-shadow: 0 12px 35px rgba(0,0,0,.12);
    }

    .add-loan-btn {
        margin-top: 2rem;
        padding: 12px 24px;
        border: none;
        border-radius: 12px;
        background: #003358;
        color: #fff;
        font-weight: 600;
    }

    footer {
        margin-top: 5rem;
        padding: 2rem 0;
    }

    @@media(max-width:900px) {
        .title-container h1 {
            font-size: 54px;
        }

        .feature-image img {
            height: 300px;
        }
    }
</style>

