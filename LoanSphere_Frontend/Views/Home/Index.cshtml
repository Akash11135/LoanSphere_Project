@{
    ViewData["Title"] = "LoanSphere";
}

<section class="public-hero-grid">
    <div class="hero-copy card-surface">
        <p class="eyebrow">Institutional Capital</p>
        <h1 class="marketing-headline">
            The Architectural Ledger of
            <span class="headline-accent">Strategic Finance</span>
        </h1>
        <p class="subtle-copy">
            Precision-engineered credit facilities for institutional growth. LoanSphere unifies secure onboarding,
            profile intelligence, underwriting visibility, and amortization-ready lending operations in one navigable system.
        </p>
        <div class="hero-actions">
            <a class="solid-button" asp-controller="Account" asp-action="Register">Apply Now</a>
            <a class="outline-button" asp-controller="Account" asp-action="Login">Log In</a>
        </div>
        <div class="metric-band">
            <span class="mini-stat">$42.8M capital monitored</span>
            <span class="mini-stat">Role-secure onboarding</span>
            <span class="mini-stat">Live EMI visibility</span>
        </div>
    </div>

    <div class="hero-side-column">
        <div>
            <p class="eyebrow">Institutional Capital Directory</p>
            <h2>Global network of strategic partners.</h2>
            <p>Connect with capital partners, compliance-ready workflows, and underwriting desks built for structured lending.</p>
        </div>
        <div class="auth-note-card">
            <strong>Primary Capability</strong>
            <p>Customer, manager, and admin journeys presented through one consistent interface.</p>
        </div>
    </div>
</section>

<section class="public-market-grid public-section" id="products">
    <aside class="filter-column">
        <div class="filter-card">
            <p class="eyebrow">Capital Themes</p>
            <h3>Market Sectors</h3>
            <div class="filter-list">
                <div class="filter-item"><span>Infrastructure</span><strong>Open</strong></div>
                <div class="filter-item"><span>Real Estate Development</span><strong>Priority</strong></div>
                <div class="filter-item is-muted"><span>Sustainable Energy</span><strong>Reviewing</strong></div>
                <div class="filter-item is-muted"><span>SME Growth Capital</span><strong>Available</strong></div>
            </div>
        </div>
        <div class="trust-card">
            <p class="eyebrow">Institutional Standard</p>
            <h3>Built for serious lending operations.</h3>
            <p>Secure onboarding, profile-linked eligibility, approval oversight, and EMI schedule intelligence aligned into one interface.</p>
        </div>
    </aside>

    <div>
        <div class="product-grid">
            <article class="product-card">
                <span class="card-icon" aria-hidden="true">CM</span>
                <div class="card-title-row">
                    <h3>Commercial Mortgages</h3>
                    <span class="chip-badge">Preferred Rates</span>
                </div>
                <p>Tier-1 real estate acquisition and refinancing facilities for high-volume urban developments and logistics corridors.</p>
                <div class="card-inline-actions">
                    <span class="route-chip">LTV up to 80%</span>
                    <span class="topbar-link is-active">Learn More</span>
                </div>
            </article>

            <article class="product-card">
                <span class="card-icon" aria-hidden="true">ES</span>
                <div class="card-title-row">
                    <h3>ESG Infrastructure</h3>
                    <span class="chip-badge">Climate-linked</span>
                </div>
                <p>Structured capital for sustainable energy, modern manufacturing, and carbon-aware urban infrastructure programs.</p>
                <div class="card-inline-actions">
                    <span class="route-chip">Long-tenor credit</span>
                    <span class="topbar-link is-active">Learn More</span>
                </div>
            </article>

            <article class="product-card">
                <span class="card-icon" aria-hidden="true">EC</span>
                <div class="card-title-row">
                    <h3>Expansion Credit</h3>
                    <span class="chip-badge">Flexible terms</span>
                </div>
                <p>Operating credit lines for multi-jurisdiction growth initiatives, strategic hiring, and capability transformation.</p>
                <div class="card-inline-actions">
                    <span class="route-chip">Unsecured tiers</span>
                    <span class="topbar-link is-active">Learn More</span>
                </div>
            </article>
        </div>

        <div class="partner-grid" id="partners">
            <article class="partner-card">
                <span class="card-icon" aria-hidden="true">GF</span>
                <div class="card-title-row">
                    <div>
                        <h3>Global Capital Fund</h3>
                        <p>Infrastructure and urban renewal</p>
                    </div>
                    <span class="chip-badge">Primary Partner</span>
                </div>
                <p>Critical mezzanine financing for high-yield urban infrastructure and long-horizon redevelopment assets.</p>
                <div class="card-inline-actions">
                    <span class="route-chip">AUM $14.2B</span>
                    <span class="topbar-link is-active">View Portfolio</span>
                </div>
            </article>

            <article class="partner-card">
                <span class="card-icon" aria-hidden="true">MT</span>
                <div class="card-title-row">
                    <div>
                        <h3>Meridian Trust</h3>
                        <p>Commercial real estate</p>
                    </div>
                    <span class="chip-badge">Structured Desk</span>
                </div>
                <p>A cornerstone capital partner focused on acquisition-driven lending and premium asset modernization.</p>
                <div class="card-inline-actions">
                    <span class="route-chip">AUM $8.5B</span>
                    <span class="topbar-link is-active">View Portfolio</span>
                </div>
            </article>
        </div>
    </div>
</section>

<section class="public-section" id="about">
    <div class="section-heading">
        <div>
            <p class="eyebrow">Platform Workflow</p>
            <h2>Depth where your team wants it.</h2>
            <p>Each screen reinforces secure access, identity completion, application review, and repayment visibility.</p>
        </div>
    </div>

    <div class="workflow-grid">
        <article class="workflow-card">
            <p class="eyebrow">Step 1</p>
            <h3>Role-aware onboarding</h3>
            <p>Customers enter directly, while managers and admins unlock protected roles through secure access key flows.</p>
        </article>
        <article class="workflow-card">
            <p class="eyebrow">Step 2</p>
            <h3>Profile-linked underwriting</h3>
            <p>PAN, Aadhaar, profile imagery, and CIBIL-driven completeness cues give every downstream screen stronger context.</p>
        </article>
        <article class="workflow-card">
            <p class="eyebrow">Step 3</p>
            <h3>Portfolio-grade monitoring</h3>
            <p>Dashboards, ledger cards, and amortization tables surface the structured loan logic already present in the backend.</p>
        </article>
    </div>
</section>

<section class="public-section" id="contact">
    <div class="contact-band card-surface">
        <div>
            <p class="eyebrow">Contact the Capital Desk</p>
            <h2>Ready to position the platform for review?</h2>
            <p class="subtle-copy">Present the app as a secure loan operations console with a clearer hierarchy and tighter desktop fit.</p>
        </div>
        <div class="panel-card">
            <h3>Delivery Notes</h3>
            <p>Manrope-based typography, the reference palette, and a more compact composition across landing, onboarding, dashboard, profile, and loan detail screens.</p>
            <div class="card-inline-actions">
                <a class="solid-button" asp-controller="Account" asp-action="Register">Start the Flow</a>
                <a class="outline-button" asp-controller="Account" asp-action="Login">Review Access</a>
            </div>
        </div>
    </div>
</section>
