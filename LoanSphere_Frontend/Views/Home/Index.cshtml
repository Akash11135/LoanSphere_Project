@{
    ViewData["Title"] = "Home Page";
}
<style>
    .main-container{
        margin-top:6rem;
    }

    .title-container h1{
        
        font-size:72px;
        color:#003358;
        font-weight:bolder;
    }

    .title-container p{
        max-width:672px;
        color: #42474F;
        
    }

    .services-container {
        margin-top: 3rem;
        width:100%;
        display:flex;
        justify-content:space-evenly;
        align-items:center;
        flex-wrap:wrap;
        gap:2rem;
    }

    .service-card {
        width: 362px;
        height: 411px;
        border-radius: 20px;
        background-color: #F5F7F9;
        padding: 32px;
        display: flex;
        flex-direction: column;
        justify-content: space-between;
        transition: all 0.35s cubic-bezier(0.25, 1, 0.5, 1);
        transform: translateY(0);
        cursor: pointer;
    }

        /* Hover animation (lift + smooth return) */
        .service-card:hover {
            transform: translateY(-10px) scale(1.02);
            box-shadow: 0 20px 40px rgba(0, 0, 0, 0.08);
        }

    /* Icon container (like image) */
    .icon-box {
        width: 48px;
        height: 48px;
        border-radius: 12px;
        background: #E9EEF3;
        display: flex;
        align-items: center;
        justify-content: center;
    }

        .icon-box i {
            color: #003358;
            font-size: 20px;
        }

    .service-card h4 {
        color: #003358;
        font-weight: 600;
        margin-top: 20px;
    }

    .service-card p {
        color: #42474F;
        border-bottom: 1px solid #E0E4E8;
        padding-bottom: 2rem;
        margin-top: 10px;
    }

    /* Bottom section */
    .card-footer {
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    /* Learn more button */
    .learn-more {
        background: none;
        border: none;
        color: #003358;
        font-weight: 500;
        display: flex;
        align-items: center;
        gap: 6px;
        cursor: pointer;
        transition: all 0.3s ease;
    }

        /* Arrow animation */
        .learn-more span {
            display: inline-block;
            transition: transform 0.3s ease;
        }

    /* Move arrow on hover */
    .service-card:hover .learn-more span {
        transform: translateX(6px);
    }

    .feature-section {
        margin-top: 6rem;
        background: #F5F7F9;
        border-radius: 30px;
        padding: 60px;
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 3rem;
        flex-wrap: wrap;
    }

    /* Left content */
    .feature-text {
        flex: 1;
        min-width: 300px;
    }

        .feature-text h2 {
            font-size: 36px;
            color: #003358;
            font-weight: 700;
        }

        .feature-text p {
            margin-top: 1rem;
            color: #42474F;
            max-width: 500px;
        }

    /* Feature points */
    .feature-item {
        display: flex;
        gap: 12px;
        margin-top: 20px;
    }

    .feature-icon {
        width: 36px;
        height: 36px;
        border-radius: 10px;
        background: #E9EEF3;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #006A6A;
    }

    /* Right image */
    .feature-image {
        flex: 1;
        min-width: 300px;
        position: relative;
    }

        .feature-image img {
            width: 100%;
            border-radius: 25px;
            object-fit: cover;
        }

    /* Floating stat card */
    .stat-card {
        position: absolute;
        bottom: -20px;
        left: 30px;
        background: white;
        padding: 20px 30px;
        border-radius: 15px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.1);
    }

        .stat-card h3 {
            margin: 0;
            color: #003358;
            font-weight: 700;
        }

        .stat-card span {
            font-size: 12px;
            color: #777;
        }

    .feature-image img {
        transition: transform 0.4s ease;
    }

    .feature-image:hover img {
        transform: scale(1.03);
    }
    .add-loan-btn {
        margin-top: 2rem;
        padding: 12px 24px;
        background: #003358;
        color: #ffffff;
        border: none;
        border-radius: 10px;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.3s ease;
    }

        /* Hover effect */
        .add-loan-btn:hover {
            background: #005A8D;
            transform: translateY(-2px);
            box-shadow: 0 10px 20px rgba(0, 51, 88, 0.2);
        }
</style>
