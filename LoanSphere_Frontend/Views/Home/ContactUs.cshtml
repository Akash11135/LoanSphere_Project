@{
    ViewData["Title"] = "Contact Us";
}

<body class="ls-app">

    @await Html.PartialAsync("_Sidebar")

    <main class="ls-main">

        <!-- Header -->
        <div class="ls-page-header ls-mb-4">
            <div class="ls-page-title">Contact Us</div>
            <div class="ls-page-sub">We're here to help — reach us through any channel below</div>
        </div>

        <!-- Contact Channel Cards -->
        <div class="ls-grid-3 ls-mb-4">
            <a href="tel:+18001234567" class="ls-contact-card" style="text-decoration:none;">
                <div class="ls-contact-icon">
                    <i data-lucide="phone-call"></i>
                </div>
                <div>
                    <h4>Call Us</h4>
                    <p>1800 123 4567 (Toll Free)</p>
                    <p style="margin-top:2px;font-size:.7rem;color:var(--ls-text-muted);">Mon–Sat, 9 AM – 6 PM</p>
                </div>
            </a>

            <a href="mailto:support@loansphere.in" class="ls-contact-card" style="text-decoration:none;">
                <div class="ls-contact-icon">
                    <i data-lucide="mail"></i>
                </div>
                <div>
                    <h4>Email Support</h4>
                    <p>support@loansphere.in</p>
                    <p style="margin-top:2px;font-size:.7rem;color:var(--ls-text-muted);">Response within 24 hrs</p>
                </div>
            </a>

            <div class="ls-contact-card" onclick="openChat()">
                <div class="ls-contact-icon">
                    <i data-lucide="message-circle"></i>
                </div>
                <div>
                    <h4>Live Chat</h4>
                    <p>Chat with our agents</p>
                    <p style="margin-top:2px;">
                        <span class="ls-status ls-status-active" style="font-size:.65rem;">Online Now</span>
                    </p>
                </div>
            </div>
        </div>

        <div class="ls-grid-2" style="gap:2rem;align-items:start;">

            <!-- Contact Form -->
            <div class="ls-card" style="padding:2rem;">
                <h3 style="font-weight:700;font-size:.95rem;margin-bottom:.3rem;">Send us a Message</h3>
                <p style="font-size:.78rem;color:var(--ls-text-muted);margin-bottom:1.5rem;">Our team typically responds within 1 business day.</p>

                <form asp-controller="Home" asp-action="SubmitContact" method="post" id="contactForm">
                    @Html.AntiForgeryToken()

                    <div class="ls-form-group">
                        <label class="ls-label">Subject</label>
                        <select class="ls-select" name="Subject" required>
                            <option value="">Select a topic</option>
                            <option>EMI Payment Issue</option>
                            <option>Loan Application Query</option>
                            <option>Account Access Problem</option>
                            <option>Document Submission</option>
                            <option>Interest Rate Enquiry</option>
                            <option>Prepayment / Foreclosure</option>
                            <option>Statement Request</option>
                            <option>Other</option>
                        </select>
                    </div>

                    <div class="ls-form-group">
                        <label class="ls-label">Loan Reference (optional)</label>
                        <div class="ls-input-group">
                            <i data-lucide="hash" class="ls-input-icon"></i>
                            <input type="text" class="ls-input" name="LoanRef"
                                   placeholder="LN-XXXXX" />
                        </div>
                    </div>

                    <div class="ls-form-group">
                        <label class="ls-label">Priority</label>
                        <div style="display:flex;gap:.6rem;flex-wrap:wrap;">
                            @foreach (var (p, color) in new[]{
                                                        ("Low","var(--ls-success)"),
                                                        ("Medium","var(--ls-warning)"),
                                                        ("High","var(--ls-danger)")
                                                        })
                            {
                                <label style="cursor:pointer;display:flex;align-items:center;gap:6px;font-size:.8rem;font-weight:500;">
                                    <input type="radio" name="Priority" value="@p" @(p == "Medium" ? "checked" : "") />
                                    <span style="width:8px;height:8px;border-radius:50%;background:@color;display:inline-block;"></span>
                                    @p
                                </label>
                            }
                        </div>
                    </div>

                    <div class="ls-form-group">
                        <label class="ls-label">Your Message</label>
                        <textarea class="ls-textarea" name="Message"
                                  placeholder="Describe your issue or question in detail..."
                                  required style="min-height:130px;"></textarea>
                        <div class="ls-form-hint">Minimum 20 characters</div>
                    </div>

                    <div class="ls-form-group">
                        <label class="ls-label">Preferred Contact Method</label>
                        <div style="display:flex;gap:1rem;">
                            @foreach (var m in new[] { "Email", "Phone", "Any" })
                            {
                                <label style="display:flex;align-items:center;gap:5px;font-size:.82rem;cursor:pointer;">
                                    <input type="radio" name="ContactMethod" value="@m" @(m == "Email" ? "checked" : "") />
                                    @m
                                </label>
                            }
                        </div>
                    </div>

                    <button type="submit" class="ls-btn ls-btn-primary ls-w-full ls-btn-lg"
                            style="justify-content:center;">
                        <i data-lucide="send"></i>
                        Submit Request
                    </button>

                </form>
            </div>

            <!-- Right Column -->
            <div>

                <!-- FAQ -->
                <div class="ls-card" style="padding:2rem;margin-bottom:1.5rem;">
                    <h3 style="font-weight:700;font-size:.9rem;margin-bottom:1.2rem;">Frequently Asked Questions</h3>

                    @foreach (var (q, a) in new[]{
                                        (
                                        "How do I pay my EMI?",
                                        "Go to 'EMI Payments' from the sidebar or click 'Pay EMI' on your loan card. You can pay via UPI, Net Banking, or Debit/Credit Card."
                                        ),
                                        (
                                        "What happens if I miss an EMI?",
                                        "A late fee is applied after the due date. Continued non-payment may affect your credit score. Contact us to discuss restructuring options."
                                        ),
                                        (
                                        "How can I download my loan statement?",
                                        "Navigate to Loan Details and click the 'Statement' button. Statements are generated in PDF format."
                                        ),
                                        (
                                        "Can I prepay or foreclose my loan?",
                                        "Yes. Partial prepayment and full foreclosure are allowed after 6 EMIs. Standard foreclosure charges apply. Contact support for a quote."
                                        ),
                                        (
                                        "How long does loan approval take?",
                                        "Most applications are processed within 2–3 business days. You'll receive an SMS and email when the decision is made."
                                        )
                                        })
                    {
                        <div class="ls-accordion-item">
                            <div class="ls-accordion-header" onclick="toggleAccordion(this)">
                                @q
                                <i data-lucide="chevron-down"></i>
                            </div>
                            <div class="ls-accordion-body">
                                <p>@a</p>
                            </div>
                        </div>
                    }
                </div>

                <!-- Office Info -->
                <div class="ls-card" style="padding:2rem;">
                    <h3 style="font-weight:700;font-size:.9rem;margin-bottom:1.2rem;">
                        <i data-lucide="map-pin" style="width:15px;height:15px;vertical-align:middle;margin-right:5px;color:var(--ls-primary);"></i>
                        Visit Our Office
                    </h3>

                    <div style="background:var(--ls-surface-2);border:1px solid var(--ls-border);border-radius:var(--ls-radius-md);padding:1.2rem;margin-bottom:1.2rem;">
                        <div style="font-size:.85rem;font-weight:600;margin-bottom:.3rem;">LoanSphere Head Office</div>
                        <div style="font-size:.78rem;color:var(--ls-text-muted);line-height:1.8;">
                            12th Floor, Financial Tower<br />
                            Sector 17, Chandigarh – 160017<br />
                            Punjab, India
                        </div>
                    </div>

                    <div style="display:flex;flex-direction:column;gap:.7rem;">
                        <div class="ls-flex-center ls-gap-1" style="font-size:.8rem;color:var(--ls-text-secondary);">
                            <i data-lucide="clock" style="width:14px;height:14px;color:var(--ls-primary);flex-shrink:0;"></i>
                            Mon – Sat &nbsp;|&nbsp; 9:00 AM – 6:00 PM
                        </div>
                        <div class="ls-flex-center ls-gap-1" style="font-size:.8rem;color:var(--ls-text-secondary);">
                            <i data-lucide="phone" style="width:14px;height:14px;color:var(--ls-primary);flex-shrink:0;"></i>
                            +91 172 400 5000
                        </div>
                        <div class="ls-flex-center ls-gap-1" style="font-size:.8rem;color:var(--ls-text-secondary);">
                            <i data-lucide="globe" style="width:14px;height:14px;color:var(--ls-primary);flex-shrink:0;"></i>
                            www.loansphere.in
                        </div>
                    </div>

                    <div style="margin-top:1.2rem;padding-top:1rem;border-top:1px solid var(--ls-border);">
                        <div style="font-size:.72rem;font-weight:600;color:var(--ls-text-muted);text-transform:uppercase;letter-spacing:.07em;margin-bottom:.7rem;">Follow Us</div>
                        <div style="display:flex;gap:.6rem;">
                            @foreach (var (icon, color) in new[]{
                                                        ("twitter","#1DA1F2"),
                                                        ("linkedin","#0A66C2"),
                                                        ("facebook","#1877F2"),
                                                        ("instagram","#E1306C")
                                                        })
                            {
                                <a href="#"
                                   style="width:32px;height:32px;border-radius:var(--ls-radius-sm);background:var(--ls-surface-2);border:1px solid var(--ls-border);display:flex;align-items:center;justify-content:center;transition:all .18s;"
                                   onmouseover="this.style.borderColor='@color';this.style.background='transparent'"
                                   onmouseout="this.style.borderColor='';this.style.background='var(--ls-surface-2)'">
                                    <i data-lucide="@icon" style="width:14px;height:14px;color:@color;"></i>
                                </a>
                            }
                        </div>
                    </div>
                </div>

            </div>
        </div>

        <!-- Success toast placeholder -->
        <div id="successToast" style="display:none;position:fixed;bottom:2rem;right:2rem;background:var(--ls-success);color:#fff;padding:.9rem 1.5rem;border-radius:12px;font-size:.82rem;font-weight:600;box-shadow:var(--ls-shadow-lg);z-index:999;">
            ✓ Message sent! We'll respond within 24 hours.
        </div>

    </main>
</body>

<script>
    lucide.createIcons();

    function toggleAccordion(header) {
        const item = header.closest('.ls-accordion-item');
        const wasOpen = item.classList.contains('open');
        document.querySelectorAll('.ls-accordion-item.open').forEach(i => i.classList.remove('open'));
        if (!wasOpen) item.classList.add('open');
    }

    function openChat() {
        alert('Live chat is loading…');
    }

    document.getElementById('contactForm')?.addEventListener('submit', function (e) {
        e.preventDefault();
        const toast = document.getElementById('successToast');
        toast.style.display = 'block';
        setTimeout(() => toast.style.display = 'none', 4000);
        this.reset();
    });
</script>
