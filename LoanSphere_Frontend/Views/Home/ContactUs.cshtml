@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width,initial-scale=1.0">
    <title>Contact Us</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@200..800&display=swap" rel="stylesheet">
    <script src="https://unpkg.com/lucide@latest"></script>
    <link rel="stylesheet" href="~/css/site.css" />
    <style>
      
        body{
            font-family:Manrope ;
        }

        .contact-hero {
            background: linear-gradient(135deg,#0f172a,#1e3a5f);
            color: #fff;
            padding: 3rem;
            border-radius: 1rem;
            margin-bottom: 2rem;
        }

        .contact-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 2rem;
        }

        .cardx {
            background: white;
            padding: 2rem;
            border-radius: 1rem;
            border: 1px solid #e5e7eb;
        }

        input, textarea {
            width: 100%;
            padding: .9rem 1rem;
            border: 1px solid #d1d5db;
            border-radius: .7rem;
            margin-top: .5rem;
            margin-bottom: 1rem;
        }

        .contact-item {
            display: flex;
            gap: 1rem;
            margin-bottom: 1.5rem;
            align-items: flex-start;
        }
    </style>
</head>
<body class="ls-app">
    <div class="ls-layout">

        <div class="ls-sidebar">
            <div class="ls-sidebar-brand">
                <span class="ls-brand-name">LoanSphere</span>
            </div>
            <a href="/Dashboard" class="ls-nav-item">Dashboard</a>
            <a href="/AboutUs" class="ls-nav-item">About Us</a>
            <a href="/ContactUs" class="ls-nav-item active">Contact</a>
        </div>

        <div style="display:flex;flex-direction:column;margin-left:9rem;width:100%;">
            <header class="ls-topbar">
                <span class="ls-page-title">Contact Us</span>
            </header>

            <main class="ls-main">

                <div class="contact-hero">
                    <h1>Let's Talk</h1>
                    <p>
                        Questions about loans, repayments, support or partnerships?
                        Our team is here to help.
                    </p>
                </div>

                <div class="contact-grid">

                    <div class="cardx">
                        <h4>Send Us a Message</h4>

                        <label>Full Name</label>
                        <input value="Akash Pandey" />

                        <label>Email</label>
                        <input value="akash@email.com" />

                        <label>Subject</label>
                        <input value="Loan Product Inquiry" />

                        <label>Message</label>
<textarea rows="6">Hi team, I'd like to know more about education loan products and eligibility.</textarea>

                        <button class="ls-btn ls-btn-primary">
                            Submit Inquiry
                        </button>
                    </div>

                    <div>
                        <div class="cardx mb-4">
                            <h4>Reach Us</h4>

                            <div class="contact-item">
                                <i data-lucide="map-pin"></i>
                                <div>
                                    <b>Head Office</b><br>
                                    Sector 17, Chandigarh, India
                                </div>
                            </div>

                            <div class="contact-item">
                                <i data-lucide="phone"></i>
                                <div>
                                    <b>Support</b><br>
                                    +91 98765 43210
                                </div>
                            </div>

                            <div class="contact-item">
                                <i data-lucide="mail"></i>
                                <div>
                                    <b>Email</b><br>
                                    support@loansphere.com
                                </div>
                            </div>

                            <div class="contact-item">
                                <i data-lucide="clock"></i>
                                <div>
                                    <b>Hours</b><br>
                                    Mon - Sat | 9AM - 6PM
                                </div>
                            </div>
                        </div>

                        <div class="cardx">
                            <h4>Support Channels</h4>
                            <div class="row mt-4">
                                <div class="col-6 mb-3">
                                    <div class="p-3 border rounded">
                                        <h6>Live Chat</h6>
                                        <small>Instant support</small>
                                    </div>
                                </div>
                                <div class="col-6 mb-3">
                                    <div class="p-3 border rounded">
                                        <h6>Loan Helpdesk</h6>
                                        <small>Case escalation</small>
                                    </div>
                                </div>
                                <div class="col-6">
                                    <div class="p-3 border rounded">
                                        <h6>EMI Support</h6>
                                        <small>Repayment queries</small>
                                    </div>
                                </div>
                                <div class="col-6">
                                    <div class="p-3 border rounded">
                                        <h6>Partnerships</h6>
                                        <small>Business inquiries</small>
                                    </div>
                                </div>
                            </div>
                        </div>

                    </div>

                </div>

                <div class="cardx mt-5 text-center">
                    <h3>Need urgent assistance?</h3>
                    <p>Dedicated borrower support available 24x7.</p>
                    <a class="ls-btn ls-btn-primary">
                        Talk To Support
                    </a>
                </div>

            </main>
        </div>
    </div>

    <script>
        lucide.createIcons();
    </script>
</body>
</html>
```
