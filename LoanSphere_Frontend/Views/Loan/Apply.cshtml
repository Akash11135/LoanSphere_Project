@model LoanSphere_Frontend.Models.LoanApplicationViewModel
@{
    ViewData["Title"] = "Apply for Loan";
}

<div class="workspace-grid">
    <partial name="_InstitutionRail" />

    <div class="workspace-main">
        <section class="workspace-heading">
            <p class="eyebrow">New Application</p>
            <h1>Secure your future with a guided lending workflow.</h1>
            <p>The backend stays the same, but this screen now reads like a structured application desk: staged steps, lending context, and compliance framing around the form.</p>
        </section>

        <div class="application-grid">
            <aside class="step-card">
                <div>
                    <p class="eyebrow">Application Flow</p>
                    <h3>Institutional submission path</h3>
                    <p>Follow the same logic you already built, now presented with clearer progression and underwriting context.</p>
                </div>

                <div class="step-list">
                    <div class="step-item">
                        <span class="step-bullet is-done"></span>
                        <div class="step-copy">
                            <small>Step 1</small>
                            <strong>Identity verified</strong>
                        </div>
                    </div>
                    <div class="step-item">
                        <span class="step-bullet is-active"></span>
                        <div class="step-copy">
                            <small>Step 2</small>
                            <strong>Loan specifications</strong>
                        </div>
                    </div>
                    <div class="step-item">
                        <span class="step-bullet"></span>
                        <div class="step-copy">
                            <small>Step 3</small>
                            <strong>Decision lifecycle</strong>
                        </div>
                    </div>
                </div>

                <div class="compliance-card">
                    <p class="eyebrow">Institutional Security</p>
                    <h3>Profile-linked submission</h3>
                    <p>Your current backend already checks profile completeness before this form can proceed, so the UI now reflects that security posture more clearly.</p>
                </div>
            </aside>

            <section class="form-panel">
                <p class="eyebrow">Loan Specifications</p>
                <h3>Structure the application</h3>
                <p>Select the loan type, amount, tenor, and business purpose. The resulting application will retain the existing pending-status workflow.</p>

                <form method="post" asp-action="Apply" class="field-stack mt-4">
                    @Html.AntiForgeryToken()
                    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                    <div class="field-grid">
                        <div>
                            <label asp-for="Amount" class="form-label"></label>
                            <input asp-for="Amount" class="form-control" placeholder="500000" />
                            <span asp-validation-for="Amount" class="text-danger"></span>
                        </div>
                        <div>
                            <label asp-for="TermInMonths" class="form-label"></label>
                            <select asp-for="TermInMonths" class="form-select">
                                <option value="">Select term</option>
                                <option value="12">12 months</option>
                                <option value="24">24 months</option>
                                <option value="36">36 months</option>
                                <option value="60">60 months</option>
                                <option value="84">84 months</option>
                                <option value="120">120 months</option>
                            </select>
                            <span asp-validation-for="TermInMonths" class="text-danger"></span>
                        </div>
                    </div>

                    <div>
                        <label class="form-label">Purpose of loan</label>
                        <div class="selection-grid">
                            <label class="choice-card">
                                <input asp-for="LoanType" type="radio" value="House" />
                                <span class="choice-content">
                                    <span class="choice-title">House</span>
                                    <span class="choice-copy">Structured home acquisition and refinancing support.</span>
                                </span>
                            </label>
                            <label class="choice-card">
                                <input asp-for="LoanType" type="radio" value="Education" />
                                <span class="choice-content">
                                    <span class="choice-title">Education</span>
                                    <span class="choice-copy">Long-horizon academic and professional advancement funding.</span>
                                </span>
                            </label>
                            <label class="choice-card">
                                <input asp-for="LoanType" type="radio" value="Personal" />
                                <span class="choice-content">
                                    <span class="choice-title">Personal</span>
                                    <span class="choice-copy">Flexible liquidity for multi-purpose capital requirements.</span>
                                </span>
                            </label>
                            <label class="choice-card">
                                <input asp-for="LoanType" type="radio" value="Business" />
                                <span class="choice-content">
                                    <span class="choice-title">Business</span>
                                    <span class="choice-copy">Growth capital for operations, expansion, and reinvestment.</span>
                                </span>
                            </label>
                        </div>
                        <span asp-validation-for="LoanType" class="text-danger"></span>
                    </div>

                    <div>
                        <label asp-for="Purpose" class="form-label"></label>
                        <textarea asp-for="Purpose" class="form-control" placeholder="Describe the strategic purpose of this facility."></textarea>
                        <span asp-validation-for="Purpose" class="text-danger"></span>
                    </div>

                    <div class="compliance-card">
                        <p class="eyebrow">Verification Context</p>
                        <div class="document-list">
                            <div class="document-row">
                                <div>
                                    <strong>Profile documentation</strong>
                                    <p>PAN and Aadhaar records are already captured through the profile workflow before submission.</p>
                                </div>
                                <span class="document-status">Profile-linked</span>
                            </div>
                            <div class="document-row">
                                <div>
                                    <strong>Application outcome</strong>
                                    <p>On submit, the loan is created and immediately visible on the dashboard with pending status.</p>
                                </div>
                                <span class="document-status">Pending review</span>
                            </div>
                        </div>
                    </div>

                    <div class="hero-actions">
                        <button type="submit" class="solid-button">Submit Application</button>
                        <a class="outline-button" asp-controller="Dashboard" asp-action="Index">Back to Dashboard</a>
                    </div>
                </form>
            </section>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
