@inject LoanSphere_Frontend.Services.CurrentUserService CurrentUserService
@{
    var currentUser = CurrentUserService.GetCurrentUser();
    var currentController = ViewContext.RouteData.Values["controller"]?.ToString() ?? string.Empty;
    var currentAction = ViewContext.RouteData.Values["action"]?.ToString() ?? string.Empty;
    var initials = "LS";

    if (!string.IsNullOrWhiteSpace(currentUser?.FullName))
    {
        var parts = currentUser.FullName
            .Split(' ', StringSplitOptions.RemoveEmptyEntries)
            .Take(2)
            .Select(part => char.ToUpperInvariant(part[0]).ToString());

        var builtInitials = string.Concat(parts);
        if (!string.IsNullOrWhiteSpace(builtInitials))
        {
            initials = builtInitials;
        }
    }

    var pageModeClass = currentController == "Account"
        ? "mode-auth"
        : currentUser == null
            ? "mode-public"
            : "mode-workspace";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - LoanSphere</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/LoanSphere_Frontend.styles.css" asp-append-version="true" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@200..800&display=swap" rel="stylesheet">
</head>
<body class="@pageModeClass">
    <div class="app-frame">
        <header class="topbar">
            <div class="topbar-brand">
                <a class="brand-lockup" asp-controller="Home" asp-action="Index">
                    <span class="brand-emblem">LS</span>
                    <span class="brand-copy">
                        <strong>LoanSphere</strong>
                        <small>Architectural Ledger</small>
                    </span>
                </a>
            </div>

            <nav class="topbar-nav">
                @if (currentUser == null)
                {
                    <a class="topbar-link" asp-controller="Home" asp-action="Index" asp-fragment="products">Products</a>
                    <a class="topbar-link" asp-controller="Home" asp-action="Index" asp-fragment="partners">Market Rates</a>
                    <a class="topbar-link" asp-controller="Home" asp-action="Index" asp-fragment="about">About Us</a>
                    <a class="topbar-link" asp-controller="Home" asp-action="Index" asp-fragment="contact">Contact</a>
                }
                else
                {
                    <a class="topbar-link @(currentController == "Dashboard" ? "is-active" : string.Empty)" asp-controller="Dashboard" asp-action="Index">Dashboard</a>
                    <a class="topbar-link @(currentController == "Loan" && currentAction == "Apply" ? "is-active" : string.Empty)" asp-controller="Loan" asp-action="Apply">Apply</a>
                    <a class="topbar-link @(currentController == "Profile" ? "is-active" : string.Empty)" asp-controller="Profile" asp-action="Edit">Identity</a>
                }
            </nav>

            <div class="topbar-actions">
                @if (currentUser == null)
                {
                    <a class="ghost-button" asp-controller="Account" asp-action="Login">Log In</a>
                    <a class="solid-button" asp-controller="Account" asp-action="Register">Apply Now</a>
                }
                else
                {
                    <span class="secure-pill">Protected Access</span>
                    <div class="account-chip">
                        <span class="account-avatar">@initials</span>
                        <div>
                            <strong>@currentUser.FullName</strong>
                            <small>@currentUser.Role</small>
                        </div>
                    </div>
                    <form method="post" asp-controller="Account" asp-action="Logout">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="ghost-button">Sign Out</button>
                    </form>
                }
            </div>
        </header>

        <main class="page-shell">
            @if (TempData["StatusMessage"] is string statusMessage)
            {
                <div class="status-banner success-banner" data-auto-dismiss="true" role="status">@statusMessage</div>
            }

            @if (TempData["ErrorMessage"] is string errorMessage)
            {
                <div class="status-banner error-banner" data-auto-dismiss="true" role="alert">@errorMessage</div>
            }

            @RenderBody()
        </main>

        <footer class="footer-shell">
            <div>
                <strong>LoanSphere</strong>
                <p>Institutional lending workflows with secure identity, profile, and amortization visibility.</p>
            </div>
            <div class="footer-links">
                <a asp-controller="Home" asp-action="Index" asp-fragment="about">About</a>
                <a asp-controller="Home" asp-action="Index" asp-fragment="contact">Contact</a>
                <a asp-controller="Home" asp-action="Privacy">Privacy</a>
            </div>
        </footer>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
