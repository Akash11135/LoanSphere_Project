</head>
<body class="ls-app">
    <div class="ls-layout">
        <div class="ls-sidebar">
            <div class="ls-sidebar-brand"><span class="ls-brand-name">LoanSphere</span></div>
            <a href="/Dashboard" class="ls-nav-item active">Dashboard</a>
            <a href="/LoanPipeline" class="ls-nav-item">Loan Pipeline</a>
        </div>

        <div style="display:flex;flex-direction:column;margin-left:9rem;">
            <header class="ls-topbar">
                <div>Loan Details — @Model.LoanId</div>
            </header>

            <main class="ls-main" style="margin-left:0;">

                <div class="ls-hero-card">
                    <div style="">
                        <div class="ls-hero-label">Active Portfolio — LN:@Model.LoanId</div>
                        <div class="ls-hero-value">Rs @Model.Amount.ToString("N2")</div>
                        <div class="ls-hero-sub" style="gap:2rem; margin-top:1rem;">
                            <span class="ls-loan-hero-meta-item">@Model.LoanType.ToUpper() LOAN</span>
                            <span class="ls-loan-hero-meta-item">60 Month Term</span>
                            <span class="ls-loan-hero-meta-item">@Model.InterestRate % Interest</span>
                            <span class="ls-loan-hero-meta-item">Applied at: @Model.AppliedAt.ToString("yyyy MMM,dd")</span>
                        </div>
                    </div>
                    <div>
                        <span style="color:green; display:inline-flex;msrgin-top
:1rem;"><i data-lucide="shield-check"></i>Active</span>
                    </div>
                </div>

                <div class="ls-metrics-row">
                    <div class="ls-metric-card">
                        <div class="ls-metric-label">Principal Amount</div>
                        <div class="ls-metric-value">Rs @Model.Amount</div>
                    </div>
                    <div class="ls-metric-card">
                        <div class="ls-metric-label">Monthly EMI</div>
                        <div class="ls-metric-value">Rs @Model.EMIAmount.ToString("N2")</div>
                    </div>
                    <div class="ls-metric-card">
                        <div class="ls-metric-label">Total Payable</div>
                        <div class="ls-metric-value">Rs @Model.TotalPayable.ToString("N2")</div>
                    </div>
                    <div class="ls-metric-card">
                        <div class="ls-metric-label">Amount Paid</div>
                        <div class="ls-metric-value">Rs @Model.TotalPaid.ToString("N2")</div>
                    </div>
                </div>

                <div class="ls-repay-progress-wrap">
                    <div style="display:flex;justify-content:space-between">
                        <span>Repayment Progress</span>
                        <span>50% Completed</span>
                    </div>
                    <div class="ls-repay-bar-bg">
                        <div class="ls-repay-bar-fill"></div>
                    </div>
                    <div style="display:flex;justify-content:space-between;margin-top:10px;">
                        <div>Paid: Rs 3,25,500</div>
                        <div>Next Due: Rs 10,850 Mar 15 2026</div>
                        <div>Remaining: Rs 3,25,500</div>
                    </div>
                </div>

                <div class="ls-detail-section">
                    <div class="ls-detail-section-header">
                        <h4>Loan Information</h4>
                    </div>

                    <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:2rem;">
                        <div><b>Loan ID</b><br>LN-@Model.LoanId</div>
                        <div><b>Borrower ID</b><br>USR-4589</div>
                        <div><b>Loan Type</b><br>@Model.LoanType</div>
                        <div><b>Principal</b><br>Rs @Model.Amount.ToString("N2")</div>
                        <div><b>Interest</b><br>@Model.InterestRate%</div>
                        <div><b>Tenure</b><br>@Model.TermInMonths Months</div>
                        <div><b>EMI</b><br>Rs @Model.EMIAmount.ToString("N2")</div>
                        <div><b>Total Payable</b><br>Rs @Model.TotalPayable.ToString("N2")</div>
                        <div><b>Docs Verified</b><br>Yes ✓</div>
                        <div><b>Applied</b><br>@Model.AppliedAt.ToString("yyyy MMM,dd")</div>
                        <div><b>Updated</b><br>@Model.UpdatedAt.ToString("yyyy MMM,dd")</div>
                        <div><b>Purpose</b><br>@Model.Purpose</div>
                    </div>
                </div>

                <div class="ls-table-container">
                    <div class="ls-table-header">
                        <h2 class="ls-table-title">EMI Schedule</h2>
                        <h2 class="ls-table-sub">Detailed EMI schedule for the loan : LN-@Model.LoanId</h2>
                    </div>
                    <table class="ls-data-table">
                        <thead >
                            <tr>
                                <th>#</th>
                                <th>Due Date</th>
                                <th>EMI</th>
                                <th>Principal</th>
                                <th>Interest</th>
                                <th>Balance</th>
                                <th>Status</th>
                            </tr>
                        </thead>
                        <tbody>
                            
                        @{
                            foreach(var emi in Model.EMISchedules)
                            {
                                
                                <tr>
                                    <td><span class="ls-month-badge">@emi.MonthNumber</span></td>
                                    <td>@emi.DueDate</td>
                                    <td>@emi.EMIAmount</td>
                                    <td>@emi.PrincipalComponent</td>
                                    <td>@emi.InterestComponent</td>
                                    <td>@emi.RemainingBalance</td>
                                    <td>
                                        @{
                                            if (emi.IsPaid)
                                            {
                                                <span class="ls-status-compeleted" style="var(--ls-status-closed)">
                                                    PAID
                                                </span>
                                            }
                                            else
                                            {
                                                <span class="ls-status ls-status-pending " style="color:var(--ls-status-pending-text)">
                                                    PENDING
                                                </span>
                                            }
                                        }
                                    </td>
                                    
                                </tr>
                            }
                        }
                        </tbody>
                    </table>

                    <div class="ls-form-group">
                        6 of 12 EMIs paid · 6 remaining
                        <br>
                        Outstanding: Rs 3,25,500
                    </div>

                </div>

            </main>
        </div>
    </div>
    <script>lucide.createIcons();</script>
</body>
</html>

