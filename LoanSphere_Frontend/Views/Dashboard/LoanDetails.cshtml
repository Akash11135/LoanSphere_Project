@model LoanManagement.Models.Loan

@{
    ViewData["Title"] = "Loan Details";

    var paidCount = Model.EMISchedules.Count(x => x.IsPaid);
    var totalEmis = Model.EMISchedules.Count();
    var progress = totalEmis > 0 ? (paidCount * 100 / totalEmis) : 0;
    var outstanding = Model.TotalPayable - Model.TotalPaid;
    var nextEmi = Model.EMISchedules.FirstOrDefault(x => !x.IsPaid);

    string statusClass = Model.Status?.ToLower() == "approved"
        ? "ls-status-active"
        : "ls-status-pending";
}

<div class="ls-app">

    @await Html.PartialAsync("_Sidebar")

    <main class="ls-main">

        <!-- Back -->
        <div class="ls-mb-3">
            <a asp-controller="Dashboard" asp-action="Index"
               class="ls-btn ls-btn-secondary ls-btn-sm" style="margin-bottom:1rem;">
                <i data-lucide="arrow-left"></i>
                Back to Dashboard
            </a>
        </div>

        <!-- Hero -->
        <div class="ls-hero-card ls-mb-4">
            <div style="display:flex;justify-content:space-between;align-items:flex-start;gap:2rem;flex-wrap:wrap;">

                <div>
                    <div class="ls-hero-label">@Model.LoanType.ToUpper() LOAN · LN-@Model.LoanId</div>
                    <div class="ls-hero-value" style="margin:10px 0 18px;">
                        ₹ @Model.Amount.ToString("N0")
                    </div>
                    <div style="display:flex;gap:10px;flex-wrap:wrap;margin-bottom:22px;">
                        <span class="ls-tag"><i data-lucide="percent" style="width:12px;height:12px;"></i>@Model.InterestRate% Interest</span>
                        <span class="ls-tag"><i data-lucide="calendar" style="width:12px;height:12px;"></i>@Model.TermInMonths Months</span>
                        <span class="ls-status ls-status-pending" style="background:rgba(251,191,36,.15);color:#FCD34D;border:none;">
                            Docs Pending
                        </span>
                    </div>
                    <div style="display:flex;gap:10px;flex-wrap:wrap;">
                        <a asp-controller="EMI" asp-action="Payments" class="ls-btn ls-btn-primary">
                            <i data-lucide="credit-card"></i> Pay EMI
                        </a>
                        <a href="#" class="ls-btn" style="background:rgba(255,255,255,.12);color:#fff;border:1px solid rgba(255,255,255,.2);">
                            <i data-lucide="file-down"></i> Statement
                        </a>
                        <a href="#" class="ls-btn" style="background:rgba(255,255,255,.07);color:rgba(255,255,255,.7);border:1px solid rgba(255,255,255,.12);">
                            <i data-lucide="paperclip"></i> Documents
                        </a>
                    </div>
                </div>

                <div style="background:rgba(255,255,255,.1);backdrop-filter:blur(12px);border:1px solid rgba(255,255,255,.15);padding:1.6rem 2rem;border-radius:18px;min-width:280px;">
                    <div class="ls-stat-label" style="color:rgba(255,255,255,.5);margin-bottom:.4rem;">NEXT EMI DUE</div>
                    <div style="font-size:2.2rem;font-weight:800;color:#fff;letter-spacing:-.02em;margin-bottom:6px;">
                        ₹ @Model.EMIAmount.ToString("N0")
                    </div>
                    <div style="font-size:.78rem;color:rgba(255,255,255,.55);margin-bottom:14px;">
                        Due: @(nextEmi?.DueDate.ToString("dd MMM yyyy") ?? "—")
                    </div>
                    <span class="ls-status ls-status-@Model.Status" style="font-size:.72rem;">
                        @Model.Status
                    </span>
                </div>

            </div>
        </div>

        <!-- Stat Cards -->
        <div class="ls-grid-4 ls-mb-4">
            <div class="ls-stat-card">
                <div class="ls-stat-icon" style="background:var(--ls-primary-light);">
                    <i data-lucide="banknote" style="color:var(--ls-primary);width:20px;height:20px;"></i>
                </div>
                <div class="ls-stat-label">Principal</div>
                <div class="ls-stat-value">₹ @Model.Amount.ToString("N0")</div>
                <div class="ls-stat-sub">Loan sanctioned</div>
            </div>
            <div class="ls-stat-card">
                <div class="ls-stat-icon" style="background:var(--ls-accent-light);">
                    <i data-lucide="calendar-check" style="color:var(--ls-accent);width:20px;height:20px;"></i>
                </div>
                <div class="ls-stat-label">Monthly EMI</div>
                <div class="ls-stat-value">₹ @Model.EMIAmount.ToString("N0")</div>
                <div class="ls-stat-sub">Auto debit enabled</div>
            </div>
            <div class="ls-stat-card">
                <div class="ls-stat-icon" style="">
                    <i data-lucide="trending-up" style="color:#D97706;width:20px;height:20px;"></i>
                </div>
                <div class="ls-stat-label">Total Payable</div>
                <div class="ls-stat-value">₹ @Model.TotalPayable.ToString("N0")</div>
                <div class="ls-stat-sub">Including interest</div>
            </div>
            <div class="ls-stat-card">
                <div class="ls-stat-icon" style="">
                    <i data-lucide="clock" style="color:#EF4444;width:20px;height:20px;"></i>
                </div>
                <div class="ls-stat-label">Outstanding</div>
                <div class="ls-stat-value">₹ @outstanding.ToString("N0")</div>
                <div class="ls-stat-sub">Pending repayment</div>
            </div>
        </div>

        <!-- Repayment Progress -->
        <div class="ls-card ls-mb-4" style="padding:2rem;">
            <div class="ls-flex-between ls-mb-2">
                <h3 style="font-weight:700;font-size:.95rem;">Repayment Progress</h3>
                <span class="ls-progress-label">@progress%</span>
            </div>
            <div class="ls-progress-wrap" style="height:10px;margin-bottom:1.8rem;">
                <div class="ls-progress-fill" style="--ls-progress-width:@(progress)%"></div>
            </div>
            <div class="ls-grid-3">
                <div class="info-box">
                    <div class="info-label">Paid EMIs</div>
                    <div class="info-value">@paidCount / @totalEmis</div>
                </div>
                <div class="info-box">
                    <div class="info-label">Amount Paid</div>
                    <div class="info-value">₹ @Model.TotalPaid.ToString("N0")</div>
                </div>
                <div class="info-box">
                    <div class="info-label">Remaining Balance</div>
                    <div class="info-value">₹ @outstanding.ToString("N0")</div>
                </div>
            </div>
        </div>

        <!-- Loan Information -->
        <div class="ls-card ls-mb-4" style="padding:2rem;">
            <h3 style="font-weight:700;font-size:.95rem;margin-bottom:1.5rem;">Loan Information</h3>
            <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:1.2rem;">
                <div class="info-box">
                    <div class="info-label">Loan ID</div>
                    <div class="info-value" style="font-family:var(--ls-font-mono);font-size:.85rem;">LN-@Model.LoanId</div>
                </div>
                <div class="info-box">
                    <div class="info-label">Borrower ID</div>
                    <div class="info-value" style="font-family:var(--ls-font-mono);font-size:.85rem;">USR-@Model.UserId</div>
                </div>
                <div class="info-box">
                    <div class="info-label">Purpose</div>
                    <div class="info-value">@Model.Purpose</div>
                </div>
                <div class="info-box">
                    <div class="info-label">Interest Rate</div>
                    <div class="info-value">@Model.InterestRate%</div>
                </div>
                <div class="info-box">
                    <div class="info-label">Tenure</div>
                    <div class="info-value">@Model.TermInMonths Months</div>
                </div>
                <div class="info-box">
                    <div class="info-label">Last Updated</div>
                    <div class="info-value">@Model.UpdatedAt.ToString("dd MMM yyyy")</div>
                </div>
            </div>
        </div>

        <!-- EMI Schedule Table -->
        <div class="ls-table-container">
            <div class="ls-table-header">
                <div>
                    <div class="ls-table-title">EMI Schedule</div>
                    <div class="ls-table-sub">@totalEmis Installments Generated</div>
                </div>
                <a href="#" class="ls-btn ls-btn-secondary ls-btn-sm">
                    <i data-lucide="download"></i> Export
                </a>
            </div>

            <div class="ls-table-scroll">
                <table class="ls-data-table">
                    <thead>
                        <tr>
                            <th>Month</th>
                            <th>Due Date</th>
                            <th>EMI Amount</th>
                            <th>Principal</th>
                            <th>Interest</th>
                            <th>Balance</th>
                            <th>Status</th>
                            <th>Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var emi in Model.EMISchedules)
                        {
                            <tr>
                                <td>
                                    <div class="ls-table-entity">
                                        <div class="ls-entity-avatar">@emi.MonthNumber</div>
                                        <div class="ls-entity-name">EMI @emi.MonthNumber</div>
                                    </div>
                                </td>
                                <td>@emi.DueDate.ToString("dd MMM yyyy")</td>
                                <td class="ls-amount">₹ @emi.EMIAmount.ToString("N2")</td>
                                <td>₹ @emi.PrincipalComponent.ToString("N2")</td>
                                <td>₹ @emi.InterestComponent.ToString("N2")</td>
                                <td class="ls-amount">₹ @emi.RemainingBalance.ToString("N2")</td>
                                <td>
                                    @if (emi.IsPaid)
                                    {
                                        <span class="ls-status ls-status-active">Paid</span>
                                    }
                                    else
                                    {
                                        <span class="ls-status ls-status-pending">Pending</span>
                                    }
                                </td>
                                <td>
                                    @if (emi.IsPaid)
                                    {
                                        <button class="ls-btn ls-btn-sm ls-btn-secondary" disabled style="cursor:not-allowed;opacity:.5;">
                                            <i data-lucide="check" style="width:13px;height:13px;"></i> Paid
                                        </button>
                                    }
                                    else
                                    {
                                        <a asp-controller="EMI" asp-action="Payments"
                                           asp-route-emiId="@emi.Id"
                                           class="ls-btn ls-btn-sm ls-btn-primary">Pay Now</a>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <div class="ls-table-footer">
                <div class="ls-table-count">@paidCount paid · @(totalEmis - paidCount) remaining</div>
            </div>
        </div>

    </main>
</div>

<script>lucide.createIcons();</script>
