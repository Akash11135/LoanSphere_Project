@model LoanManagement.DTOs.DashboardDto

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>LoanSphere — Dashboard</title>

    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <script src="https://unpkg.com/lucide@latest/dist/umd/lucide.min.js"></script>
    <link rel="stylesheet" href="site.css" />

    <style>
        html, body {
            margin: 0;
            padding: 0;
            background: #f3f4f6;
        }
    </style>
</head>

<body class="ls-app">

    <div class="ls-layout">

        @await Html.PartialAsync("_Sidebar")


        <div style="display:flex;flex-direction:column;margin-left:9rem;">

            <header class="ls-topbar">
                <span class="ls-page-title">Overview</span>

                <div class="ls-search-bar">
                    <i data-lucide="search" style="width:15px;height:15px;color:#9ca3af;flex-shrink:0;"></i>
                    <input type="text" placeholder="Search transactions..." />
                </div>

                <div class="ls-topbar-right">
                    <button class="ls-icon-btn" title="Notifications">
                        <i data-lucide="bell" style="width:18px;height:18px;"></i>
                        <span class="ls-notif-dot"></span>
                    </button>
                    <div class="ls-avatar-pill" title="Admin Portal">AP</div>
                </div>
            </header>

            <main class="ls-main" style="margin-left:0;">

                <!-- Hero + Quick Actions -->
                <div class="ls-grid-2 ls-mb-6">

                    <div class="ls-hero-card">
                        <div class="ls-hero-label">Active Portfolio</div>
                        <div class="ls-hero-value">Rs @Model.TotalAmount.ToString("N2")</div>
                        <div class="ls-hero-sub">
                            <i data-lucide="shield" style="width:12px;height:12px;"></i>
                            @(Model.VerifiedLoans.Any() ? $"{Model.VerifiedLoans.First().InterestRate}% {Model.VerifiedLoans.First().LoanType} Loan" : "No Active Loan")
                        </div>

                        <div style="margin-top:2rem; display:flex; align-items:centre; justify-content:center; gap:2rem">
                            <a href="make-payment.html" class="ls-btn ls-btn-primary">
                                <i data-lucide="credit-card" style="width:14px;height:14px;"></i>
                                Make Early Payment
                            </a>
                            <a href="loan-details.html" class="ls-btn ls-btn-secondary" style="border-color:#a0c8df;color:#d6eaf5;background:rgba(255,255,255,.1);">
                                Loan Details
                            </a>
                        </div>
                    </div>

                    <div class="ls-card" style="padding:1.25rem;">
                        <div class="ls-table-title ls-mb-4" style="font-size:.8rem;text-transform:uppercase;letter-spacing:.07em;color:#6b7280;font-weight:600;">Quick Actions</div>
                        <div class="ls-grid-2" style="gap:.75rem;">
                            <a asp-controller="Dashboard" asp-action="ApplyNew" class="ls-quick-action highlighted">
                                <div class="ls-quick-action-icon"><i data-lucide="plus-circle" style="width:16px;height:16px;"></i></div>
                                Apply New
                            </a>
                            <a asp-controller="Home" asp-action="ContactUs" class="ls-quick-action">
                                <div class="ls-quick-action-icon"><i data-lucide="headphones" style="width:16px;height:16px;"></i></div>
                                Support
                            </a>
                            <a asp-controller="Home" asp-action="AboutUs" class="ls-quick-action">
                                <div class="ls-quick-action-icon"><i data-lucide="file-text" style="width:16px;height:16px;"></i></div>
                                Statements
                            </a>
                            <a href="https://www.google.com/search?q=calculator" class="ls-quick-action">
                                <div class="ls-quick-action-icon" style="background:#fef3c7;color:#b45309;"><i data-lucide="calculator" style="width:16px;height:16px;"></i></div>
                                Calculator
                            </a>
                        </div>
                    </div>

                </div>

                <!-- Stat Cards -->
                <div class="ls-grid-4 ls-mb-6">

                    <div class="ls-stat-card">
                        <div class="ls-stat-label">Total Loaned</div>
                        <div class="ls-stat-value">Rs @Model.TotalAmount.ToString("N2")</div>
                        <div class="ls-stat-sub" style="display:flex;align-items:center;gap:.25rem;">
                            <i data-lucide="trending-up" style="width:12px;height:12px;color:#0d6f4f;"></i>
                            <span style="color:#0d6f4f;font-weight:600;">+12.4%</span>
                        </div>
                    </div>

                    <div class="ls-stat-card">
                        <div class="ls-stat-label">Active Loans</div>
                        <div class="ls-stat-value">@Model.VerifiedLoans.Count</div>
                        <div class="ls-stat-sub">Across Model.VerifiedLoans.Count portfolio(s)</div>
                    </div>

                    <div class="ls-stat-card">
                        <div class="ls-stat-label">Pending Apps</div>
                        <div class="ls-stat-value">@Model.PendingLoans.Count</div>
                        <div class="ls-stat-sub" style="display:flex;align-items:center;gap:.25rem;">
                            <span style="width:6px;height:6px;border-radius:50%;background:#0d6f4f;display:inline-block;"></span>
                            Active Review Cycle
                        </div>
                    </div>

                    <div class="ls-stat-card">
                        <div class="ls-stat-label">Risk Index</div>
                        <div class="ls-stat-value">@Model.DueLoans.Count</div>
                        <div class="ls-stat-sub">Tier 1 — Secure Status</div>
                    </div>

                </div>

                <!-- Next Obligation -->
                @{
                    var nextDue = Model.DueLoans.OrderBy(d => d.DueDate).FirstOrDefault();
                }
                @if (nextDue != null)
                {
                    var totalPayable = Model.VerifiedLoans.FirstOrDefault()?.TotalPayable ?? 0;
                    var totalPaid = Model.VerifiedLoans.FirstOrDefault()?.TotalPaid ?? 0;
                    var progressPct = totalPayable > 0 ? (int)((totalPaid / totalPayable) * 100) : 0;

                    <div class="ls-obligation-card ls-mb-6">
                        <div class="ls-obligation-icon">
                            <i data-lucide="calendar-check" style="width:24px;height:24px;"></i>
                        </div>
                        <div class="ls-obligation-body">
                            <div class="ls-obligation-label">Next Obligation</div>
                            <div class="ls-obligation-amount">
                                Rs @nextDue.EMIAmount.ToString("N2")
                                <span style="font-size:.9rem;font-weight:500;color:#6b7280;">
                                    due @nextDue.DueDate.ToString("MMM dd, yyyy")
                                </span>
                            </div>
                            <div class="ls-progress-wrap" style="--ls-progress-width:@(progressPct)%;">
                                <div class="ls-progress-fill"></div>
                            </div>
                            <div class="ls-obligation-note">
                                <i data-lucide="credit-card" style="width:10px;height:10px;display:inline;"></i>
                                Automatic debit scheduled from *8842
                            </div>
                        </div>
                        <div>
                            <span class="ls-progress-label">@progressPct% Processed</span>
                        </div>
                    </div>
                }

                <!-- Active Loans Table -->
                <div class="ls-table-container ls-mb-6">

                    <div class="ls-table-header">
                        <div>
                            <div class="ls-table-title">Active Loans</div>
                            <div class="ls-table-sub">Currently disbursed &amp; repayment in progress</div>
                        </div>
                        <button class="ls-btn ls-btn-secondary ls-btn-sm">
                            <i data-lucide="download" style="width:13px;height:13px;"></i>
                            Export
                        </button>
                    </div>

                    <div class="ls-table-scroll">
                        <table class="ls-data-table">
                            <thead>
                                <tr>
                                    <th>Borrower</th>
                                    <th>Loan Type</th>
                                    <th>Principal</th>
                                    <th>EMI / Month</th>
                                    <th>Interest Rate</th>
                                    <th>Tenure</th>
                                    <th>Next Due</th>
                                    <th>Status</th>
                                    <th>Action</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var loan in Model.VerifiedLoans)
                                {
                                    var nextEmi = loan.EMISchedules
                                    .Where(e => !e.IsPaid)
                                    .OrderBy(e => e.DueDate)
                                    .FirstOrDefault();

                                    <tr>
                                        <td>
                                            <div class="ls-table-entity">
                                                <div class="ls-entity-avatar">UA</div>
                                                <div>
                                                    <div class="ls-entity-name">User #@loan.UserId</div>
                                                    <div class="ls-entity-id">ID: LN-@loan.LoanId</div>
                                                </div>
                                            </div>
                                        </td>
                                        <td><span class="ls-tag">@loan.LoanType.ToUpper()</span></td>
                                        <td><span class="ls-amount">Rs @loan.Amount.ToString("N2")</span></td>
                                        <td><span class="ls-amount">Rs @loan.EMIAmount.ToString("N2")</span></td>
                                        <td>@loan.InterestRate%</td>
                                        <td>@loan.TermInMonths months</td>
                                        <td>@(nextEmi != null ? nextEmi.DueDate.ToString("MMM dd, yyyy") : "—")</td>
                                        <td>
                                            <span class="ls-status @(loan.Status == "pending" ? "ls-status-review" : "ls-status-active")">
                                                @loan.Status
                                            </span>
                                        </td>
                                        <td>
                                            <a asp-controller="Dashboard" asp-action="LoanDetails" asp-route-loanId=@loan.LoanId asp-route-userId=@loan.UserId class="ls-btn ls-btn-primary ls-btn-sm">
                                                <i data-lucide="calendar-range" style="width:12px;height:12px;"></i>
                                                View Loan
                                            </a>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>

                    <div class="ls-table-footer">
                        <span class="ls-table-count">Showing @Model.VerifiedLoans.Count of @Model.VerifiedLoans.Count active loans</span>
                        <a href="loan-pipeline.html?filter=active" class="ls-view-all">View All Active →</a>
                    </div>

                </div>

                <!-- Pending Loans Table -->
                <div class="ls-table-container ls-mb-6">

                    <div class="ls-table-header">
                        <div>
                            <div class="ls-table-title">Pending Loans</div>
                            <div class="ls-table-sub">Applications under review / awaiting disbursement</div>
                        </div>
                        <div style="display:flex;gap:.5rem;">
                            <button class="ls-btn ls-btn-ghost ls-btn-sm">
                                <i data-lucide="filter" style="width:13px;height:13px;"></i>
                                Filter
                            </button>
                            <button class="ls-btn ls-btn-secondary ls-btn-sm">
                                <i data-lucide="download" style="width:13px;height:13px;"></i>
                                Export
                            </button>
                        </div>
                    </div>

                    <div class="ls-table-scroll">
                        <table class="ls-data-table">
                            <thead>
                                <tr>
                                    <th>Applicant</th>
                                    <th>Loan Type</th>
                                    <th>Requested Amount</th>
                                    <th>Submitted On</th>
                                   
                                    <th>Stage</th>
                                    <th>Status</th>
                                    <th>Action</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (Model.PendingLoans.Any())
                                {
                                    @foreach (var loan in Model.PendingLoans)
                                    {
                                        <tr>
                                            <td>
                                                <div class="ls-table-entity">
                                                    <div class="ls-entity-avatar">UA</div>
                                                    <div>
                                                        <div class="ls-entity-name">User ID:@loan.UserId</div>
                                                        <div class="ls-entity-id">ID: LN-@loan.LoanId</div>
                                                    </div>
                                                </div>
                                            </td>
                                            <td><span class="ls-tag">@loan.LoanType.ToUpper()</span></td>
                                            <td><span class="ls-amount">Rs @loan.Amount.ToString("N2")</span></td>
                                            <td>@loan.AppliedAt.ToString("MMM dd, yyyy")</td>
                                            <td>@loan.Status</td>
                                            <td><span class="ls-status ls-status-pending">Pending</span></td>
                                            <td>
                                                <a href="application-detail.html?id=LN-@loan.LoanId" class="ls-btn ls-btn-secondary ls-btn-sm">
                                                    <i data-lucide="eye" style="width:12px;height:12px;"></i>
                                                    Review
                                                </a>
                                            </td>
                                        </tr>
                                    }
                                }
                                else
                                {
                                    <tr>
                                        <td colspan="8" style="text-align:center;color:#6b7280;padding:1.5rem;">
                                            No pending applications at this time.
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>

                    <div class="ls-table-footer">
                        <span class="ls-table-count">Showing @Model.PendingLoans.Count of @Model.PendingLoans.Count pending applications</span>
                        <a href="loan-pipeline.html?filter=pending" class="ls-view-all">View All Pending →</a>
                    </div>

                </div>

                <!-- Recent Transactions (Due EMIs) -->
                <div class="ls-table-container">

                    <div class="ls-table-header">
                        <div>
                            <div class="ls-table-title">Upcomming Payments</div>
                            <div class="ls-table-sub">Upcoming &amp; due EMI schedule</div>
                        </div>
                        <a href="transactions.html" class="ls-view-all">View All Activity</a>
                    </div>

                    <div class="ls-table-scroll">
                        <table class="ls-data-table">
                            <thead>
                                <tr>
                                    <th>Transaction</th>
                                    <th>Date</th>
                                    <th>Type</th>
                                    <th>Status</th>
                                    <th style="text-align:right;">Amount</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var emi in Model.DueLoans.OrderBy(e => e.DueDate))
                                {
                                    <tr>
                                        <td>
                                            <div class="ls-table-entity">
                                                <div class="ls-entity-avatar">
                                                    <i data-lucide="repeat" style="width:13px;height:13px;"></i>
                                                </div>
                                                <div class="ls-entity-name">EMI — Month @emi.MonthNumber (LN-@emi.LoanId)</div>
                                            </div>
                                        </td>
                                        <td class="ls-text-muted">@emi.DueDate.ToString("MMM dd, yyyy")</td>
                                        <td class="ls-text-muted">Auto-Pay</td>
                                        <td>
                                            <span class="ls-status @(emi.IsPaid ? "ls-status-completed" : "ls-status-pending")">
                                                @(emi.IsPaid ? "Completed" : "Pending")
                                            </span>
                                        </td>
                                        <td style="text-align:right;">
                                            <span class="ls-amount ls-amount-debit">-Rs @emi.EMIAmount.ToString("N2")</span>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>

                    <div class="ls-table-footer">
                        <span class="ls-table-count">Showing @Model.DueLoans.Count due EMIs</span>
                        <a href="transactions.html" class="ls-view-all">View All →</a>
                    </div>

                </div>

            </main>

        </div>

    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script>lucide.createIcons();</script>

</body>
</html>